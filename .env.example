# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_gateway
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_gateway_shadow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=payment-gateway
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Security peppers
WEBHOOK_SIGNING_SECRET_PEPPER=change-me-in-production-webhook
API_KEY_PEPPER=change-me-in-production-apikey
API_KEY_ROTATION_GRACE_MS=86400000

# App
NODE_ENV=development
PORT=3000
PROCESS_TYPE=api
